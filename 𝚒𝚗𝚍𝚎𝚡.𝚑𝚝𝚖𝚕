<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sithu Studio</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Arial', sans-serif; }
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; text-align: center; padding: 50px 20px; min-height: 100vh; }
        .container { max-width: 700px; margin: 0 auto; background: rgba(255,255,255,0.1); padding: 40px; border-radius: 20px; backdrop-filter: blur(10px); }
        h1 { font-size: 3em; margin-bottom: 10px; }
        p { font-size: 1.2em; margin-bottom: 30px; opacity: 0.9; }
        .btn { display: inline-block; padding: 15px 35px; background: white; color: #764ba2; text-decoration: none; border-radius: 50px; font-weight: bold; font-size: 1.1em; transition: 0.3s; }
        .btn:hover { transform: scale(1.05); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
        footer { margin-top: 40px; opacity: 0.7; }
    </style>
</head>
<body>
    <div class="container">
        <h1>✨ Sithu Studio ✨</h1>
        <p>Bringing your ideas to life</p>
        <a href="dashboard.html" class="btn">Go to Dashboard</a>
        <footer>
            <p>Made with ❤️ by Sithu</p>
        </footer>
    </div>
</body>
</html>
